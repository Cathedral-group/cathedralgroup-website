# =============================================================================
# Cathedral Group — Plantilla de variables de entorno locales
# =============================================================================
# Copia este archivo a `.env.local` y rellena los valores reales antes de
# arrancar `npm run dev`. NO se commitea (.env.local está en .gitignore).
#
# Los valores reales están en Vercel (Production/Preview/Development) y se
# pueden bajar al disco con:
#   npx vercel env pull .env.local
#
# Las claves marcadas (server) NO se exponen al cliente. Las que empiezan por
# NEXT_PUBLIC_* sí se exponen — NUNCA poner secretos ahí (ver feedback_security).
# =============================================================================

# --- Supabase ---------------------------------------------------------------
# Cliente (browser): URL + publishable/anon key
NEXT_PUBLIC_SUPABASE_URL=https://cpqsnajuypgjjapvbqsr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Server-side (API routes /api/db/*, /api/audit/*, /api/admin/*): mismo URL
# pero con la SERVICE ROLE key (bypassa RLS). NUNCA exponer al cliente.
SUPABASE_URL=https://cpqsnajuypgjjapvbqsr.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# --- Cloudflare Turnstile (anti-bot en formulario público) ------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAA...    # publicable en cliente
TURNSTILE_SITE_KEY=0x4AAAAA...                # alias server-side
TURNSTILE_SECRET_KEY=0x4AAAAA...              # secreto server-side

# --- Auth de cron + verificador --------------------------------------------
# Usado por:
#   - /api/audit/email-coverage/* (cron auditor n8n + reprocesador)
#   - /api/verifier (n8n general llama desde nodo Llamar Verificador, sesión 31)
# Generar con: openssl rand -hex 32
# El mismo valor debe estar en n8n credential `dfTYu6xcyozU4BOs`.
AUDIT_CRON_SECRET=hex_64_chars_xxx
