      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true, skipped: true, reason: 'already_processed_or_circuit_broken' }) }}",
        "options": {
          "responseCode": 200
        }
      }
    }
